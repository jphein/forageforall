# Copy to .env and fill in. Do NOT commit .env.
# ------------------------------------------------

# InstantDB — get an app ID at https://instantdb.com/dash
INSTANT_APP_ID=
# Admin token — only needed for seed:listings (bypasses auth). Dashboard → App → Admin token.
INSTANT_ADMIN_TOKEN=

# Google Maps — enable Maps SDK (iOS), Maps SDK (Android),
# Places API, Geocoding API in Google Cloud Console.
# Restrict each key by bundle ID + SHA-1.
GOOGLE_MAPS_IOS_KEY=
GOOGLE_MAPS_ANDROID_KEY=
